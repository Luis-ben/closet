NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# mock | chatgpt-image-2
IMAGE_GENERATION_PROVIDER=mock

CHATGPT_IMAGE2_BASE_URL=https://image.codesonline.dev/v1
CHATGPT_IMAGE2_API_KEY=
CHATGPT_IMAGE2_MODEL=gpt-image-2
CHATGPT_IMAGE2_SIZE=9:16
CHATGPT_IMAGE2_QUALITY=high
CHATGPT_IMAGE2_STYLE=natural
CHATGPT_IMAGE2_RESPONSE_FORMAT=url
CHATGPT_IMAGE2_TIMEOUT_MS=120000

PUBLIC_BASE_URL=http://localhost:3000

# local | cos | wechat-cloud
IMAGE_STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
COS_PUBLIC_BASE_URL=
COS_UPLOAD_URL=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
WECHAT_CLOUD_ENV=

# memory | database
AI_TASK_QUEUE_PROVIDER=memory
AI_TASK_WORKER_INTERVAL_MS=5000

# mock | tencent-cloud | wechat-cloud
CONTENT_SAFETY_PROVIDER=mock
CONTENT_SAFETY_ENDPOINT=
CONTENT_SAFETY_API_KEY=
CONTENT_SAFETY_TIMEOUT_MS=5000

# memory | mongodb
DATA_STORE_PROVIDER=memory
DATABASE_URL=
MONGODB_DB_NAME=ai_closet

WECHAT_APP_ID=
WECHAT_APP_SECRET=
AUTH_TOKEN_SECRET=dev-only-auth-secret-change-me

.tryon-page {
  padding-bottom: 0;
}

.tryon-header {
  align-items: center;
}

.header-copy {
  min-width: 0;
}

.tryon-canvas {
  position: relative;
  height: 650rpx;
  overflow: hidden;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #EEF2F7;
  box-shadow: 0 8rpx 24rpx rgba(60, 64, 67, 0.1);
}

.tryon-canvas image {
  width: 100%;
  height: 100%;
  display: block;
}

.canvas-top {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.canvas-badge,
.canvas-change {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #202124;
  font-size: 24rpx;
  font-weight: 700;
}

.canvas-change {
  background: #111111;
  color: #FFFFFF;
}

.canvas-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 260rpx;
  background: linear-gradient(180deg, rgba(31, 31, 31, 0), rgba(31, 31, 31, 0.54));
}

.canvas-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  color: #FFFFFF;
}

.canvas-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.canvas-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

.selected-slots {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.selected-slot {
  position: relative;
  height: 184rpx;
  overflow: hidden;
  border: 2rpx dashed #DADCE0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
}

.selected-slot.is-filled {
  border-style: solid;
  border-color: #1A73E8;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(26, 115, 232, 0.16);
}

.selected-slot image {
  width: 100%;
  height: 100%;
  display: block;
}

.slot-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5F6368;
  font-size: 26rpx;
  font-weight: 700;
}

.slot-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(31, 31, 31, 0.76);
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 35rpx;
  text-align: center;
}

.slot-meta {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #202124;
  font-size: 22rpx;
  font-weight: 700;
}

.filter-section {
  margin-top: -8rpx;
}

.cloth-scroll {
  width: 100%;
  white-space: nowrap;
}

.cloth-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 4rpx;
}

.cloth-item {
  width: 232rpx;
  flex-shrink: 0;
}

.cloth-skeleton {
  width: 232rpx;
  height: 390rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
}

.style-section {
  display: grid;
  gap: 2rpx;
}

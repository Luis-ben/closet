.status-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 58rpx 34rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 36rpx;
  background: #FFFFFF;
  box-shadow: 0 16rpx 42rpx rgba(31, 31, 31, 0.08);
  text-align: center;
}

.loader-wrap {
  position: relative;
  width: 186rpx;
  height: 186rpx;
  margin-bottom: 38rpx;
}

.loader-ring {
  width: 186rpx;
  height: 186rpx;
  box-sizing: border-box;
  border: 8rpx solid #EFE5D3;
  border-top-color: #111111;
  border-radius: 50%;
  animation: spin 1.1s linear infinite;
}

.loader-wrap.success .loader-ring,
.loader-wrap.failed .loader-ring {
  animation: none;
}

.loader-wrap.failed .loader-ring {
  border-color: #D64545;
}

.loader-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 74rpx;
  height: 74rpx;
  transform: translate(-50%, -50%);
  border-radius: 28rpx;
  background: #EFE5D3;
  box-shadow: inset 0 0 0 2rpx rgba(200, 169, 106, 0.32);
}

.loader-glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 116rpx;
  height: 116rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: rgba(109, 139, 255, 0.12);
}

.status-text {
  color: #1F1F1F;
  font-size: 40rpx;
  font-weight: 800;
}

.status-hint {
  margin-top: 12rpx;
  color: #7A746E;
  font-size: 26rpx;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  margin-top: 46rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #EFE5D3;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #C8A96A, #111111);
  transition: width 0.3s ease;
}

.progress-label {
  margin-top: 14rpx;
  color: #7A746E;
  font-size: 24rpx;
  font-weight: 700;
}

.wait-copy {
  display: grid;
  gap: 6rpx;
  margin-top: 34rpx;
  color: #7A746E;
  font-size: 24rpx;
}

.error-card {
  width: 100%;
  box-sizing: border-box;
  margin-top: 30rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(214, 69, 69, 0.28);
  border-radius: 22rpx;
  background: #FFF5F5;
  color: #D64545;
  font-size: 26rpx;
  line-height: 1.45;
}

.status-actions {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.closet-page {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.model-card {
  position: relative;
  min-height: 260rpx;
  display: grid;
  grid-template-columns: 176rpx minmax(0, 1fr);
  gap: 22rpx;
  align-items: center;
  padding: 22rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 36rpx rgba(31, 31, 31, 0.06);
}

.model-card image {
  width: 176rpx;
  height: 216rpx;
  display: block;
  border-radius: 24rpx;
  background: #EFE5D3;
}

.model-copy {
  min-width: 0;
  padding-right: 88rpx;
}

.model-label {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #EFE5D3;
  color: #1F1F1F;
  font-size: 22rpx;
  font-weight: 700;
}

.model-title {
  margin-top: 18rpx;
  color: #1F1F1F;
  font-size: 32rpx;
  font-weight: 700;
}

.model-desc {
  margin-top: 8rpx;
  color: #7A746E;
  font-size: 24rpx;
  line-height: 1.45;
}

.model-action {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.category-section {
  margin-bottom: 24rpx;
}

.closet-grid {
  align-items: start;
  padding-bottom: 24rpx;
}

.cloth-card {
  min-width: 0;
}

.cloth-source {
  margin-top: 12rpx;
  padding-left: 6rpx;
  color: #7A746E;
  font-size: 22rpx;
}

.cloth-skeleton {
  height: 410rpx;
  border-radius: 24rpx;
}

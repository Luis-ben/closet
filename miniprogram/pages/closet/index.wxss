.closet-page {
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.closet-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 22rpx;
  align-items: end;
  padding-top: 6rpx;
}

.hero-copy {
  min-width: 0;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border: 1rpx solid #D2E3FC;
  border-radius: 999rpx;
  background: #E8F0FE;
  color: #174EA6;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-actions {
  display: grid;
  gap: 12rpx;
}

.hero-button {
  min-width: 132rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid #DADCE0;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #202124;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-button.primary {
  border-color: #111111;
  background: #111111;
  color: #FFFFFF;
}

.stat-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-item {
  min-width: 0;
  padding: 22rpx 18rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.stat-value {
  color: #202124;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  color: #5F6368;
  font-size: 22rpx;
}

.model-card {
  position: relative;
  min-height: 224rpx;
  display: grid;
  grid-template-columns: 148rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  padding: 18rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.08);
}

.model-card image {
  width: 148rpx;
  height: 188rpx;
  display: block;
  border-radius: 14rpx;
  background: #EEF2F7;
}

.model-copy {
  min-width: 0;
  padding-right: 86rpx;
}

.model-label {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #F1F3F4;
  color: #3C4043;
  font-size: 20rpx;
  font-weight: 700;
}

.model-title {
  margin-top: 16rpx;
  color: #202124;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.model-desc {
  margin-top: 8rpx;
  color: #5F6368;
  font-size: 24rpx;
  line-height: 1.45;
}

.model-action {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

.album-scroll,
.source-scroll {
  width: 100%;
  white-space: nowrap;
}

.album-row,
.source-row {
  display: flex;
  gap: 16rpx;
}

.album-thumb {
  position: relative;
  width: 164rpx;
  height: 216rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 16rpx;
  background: #EEF2F7;
}

.album-thumb image {
  width: 100%;
  height: 100%;
  display: block;
}

.album-source {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  overflow: hidden;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #202124;
  font-size: 20rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-chip {
  height: 64rpx;
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  padding: 0 22rpx;
  border: 1rpx solid #DADCE0;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #3C4043;
  font-size: 24rpx;
  font-weight: 700;
}

.source-chip.is-active {
  border-color: #D2E3FC;
  background: #E8F0FE;
  color: #174EA6;
}

.source-count {
  min-width: 36rpx;
  height: 36rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #F1F3F4;
  color: inherit;
  font-size: 20rpx;
}

.category-section {
  display: grid;
  gap: 2rpx;
  margin-bottom: 24rpx;
}

.closet-grid {
  align-items: start;
  padding-bottom: 24rpx;
}

.cloth-card {
  min-width: 0;
}

.cloth-source {
  margin-top: 10rpx;
  padding-left: 4rpx;
  color: #5F6368;
  font-size: 22rpx;
}

.cloth-skeleton {
  height: 410rpx;
  border-radius: 16rpx;
}

.floating-upload {
  position: fixed;
  right: 32rpx;
  bottom: calc(36rpx + env(safe-area-inset-bottom));
  z-index: 8;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #111111;
  color: #FFFFFF;
  font-size: 54rpx;
  font-weight: 300;
  line-height: 1;
  box-shadow: 0 14rpx 34rpx rgba(17, 17, 17, 0.24);
}

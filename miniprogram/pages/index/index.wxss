.index-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.redirect-card {
  width: 100%;
  display: grid;
  gap: 24rpx;
  padding: 42rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(60, 64, 67, 0.1);
}

.index-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.redirect-card {
  width: 100%;
  display: grid;
  gap: 24rpx;
  padding: 42rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 16rpx 42rpx rgba(31, 31, 31, 0.08);
}

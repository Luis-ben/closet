.cloth-edit-page {
  padding-bottom: 0;
}

.upload-box {
  position: relative;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx dashed #D8CCBA;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 12rpx 36rpx rgba(31, 31, 31, 0.04);
}

.upload-box.has-image {
  border-style: solid;
  border-color: #E9E2D8;
  background: #FFFFFF;
}

.upload-box image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7A746E;
  text-align: center;
}

.camera-icon {
  position: relative;
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 26rpx;
  border-radius: 24rpx;
  background: #111111;
}

.camera-icon::before {
  content: "";
  position: absolute;
  left: 28rpx;
  top: -14rpx;
  width: 36rpx;
  height: 24rpx;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: #111111;
}

.camera-icon::after {
  content: "";
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
}

.upload-title {
  color: #1F1F1F;
  font-size: 32rpx;
  font-weight: 800;
}

.upload-change {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #1F1F1F;
  font-size: 24rpx;
  font-weight: 700;
}

.tip-card {
  padding: 26rpx;
  border: 1rpx solid rgba(200, 169, 106, 0.34);
  border-radius: 28rpx;
  background: #EFE5D3;
}

.tip-title {
  color: #1F1F1F;
  font-size: 28rpx;
  font-weight: 700;
}

.tip-copy {
  margin-top: 10rpx;
  color: #7A746E;
  font-size: 24rpx;
  line-height: 1.55;
}

.form-section {
  display: grid;
  gap: 30rpx;
}

.form-block {
  display: grid;
  gap: 4rpx;
}

.note-input {
  width: 100%;
  min-height: 172rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 24rpx;
  background: #FFFFFF;
  color: #1F1F1F;
  font-size: 28rpx;
  line-height: 1.5;
  box-shadow: 0 8rpx 22rpx rgba(31, 31, 31, 0.04);
}

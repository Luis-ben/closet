.inspiration-page {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.result-scroll {
  width: 100%;
  white-space: nowrap;
}

.result-row {
  display: flex;
  gap: 18rpx;
}

.result-card {
  width: 256rpx;
  flex-shrink: 0;
}

.result-skeleton {
  width: 256rpx;
  height: 392rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
}

.template-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.template-card {
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 36rpx rgba(31, 31, 31, 0.06);
}

.template-card:nth-child(2n) {
  background: #EFE5D3;
}

.template-title {
  color: #1F1F1F;
  font-size: 30rpx;
  font-weight: 700;
}

.template-desc {
  margin-top: 28rpx;
  color: #7A746E;
  font-size: 24rpx;
  line-height: 1.45;
}

.recommendation-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 36rpx rgba(31, 31, 31, 0.06);
}

.recommendation-copy {
  min-width: 0;
}

.recommendation-images {
  display: flex;
  flex-shrink: 0;
}

.recommendation-images image {
  width: 78rpx;
  height: 98rpx;
  margin-left: -18rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 20rpx;
  background: #EFE5D3;
}

.recommendation-images image:first-child {
  margin-left: 0;
}

.recommendation-empty {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

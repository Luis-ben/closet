.inspiration-page {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.page-intro {
  padding-top: 6rpx;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  margin-bottom: 16rpx;
  padding: 0 18rpx;
  border: 1rpx solid #D2E3FC;
  border-radius: 999rpx;
  background: #E8F0FE;
  color: #174EA6;
  font-size: 22rpx;
  font-weight: 700;
}

.cube-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, #FFFFFF 0%, #F8FAFD 100%);
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.08);
}

.cube-card.is-complete {
  border-color: #D2E3FC;
  box-shadow: 0 10rpx 28rpx rgba(26, 115, 232, 0.12);
}

.cube-copy {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.cube-main-copy {
  min-width: 0;
}

.cube-actions {
  display: grid;
  gap: 12rpx;
  flex-shrink: 0;
}

.cube-style-pill {
  width: fit-content;
  max-width: 340rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 0 16rpx;
  border: 1rpx solid #D2E3FC;
  border-radius: 999rpx;
  background: #E8F0FE;
  color: #174EA6;
  font-size: 21rpx;
  font-weight: 700;
}

.cube-action {
  min-width: 132rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.cube-action.primary {
  background: #111111;
  color: #FFFFFF;
}

.cube-action.secondary {
  border: 1rpx solid #DADCE0;
  background: #FFFFFF;
  color: #202124;
}

.cube-status {
  display: grid;
  gap: 12rpx;
  padding: 16rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.cube-meter {
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #E8F0FE;
}

.cube-meter-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #1A73E8;
}

.cube-status-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #5F6368;
  font-size: 22rpx;
  line-height: 1.35;
}

.cube-status-copy text:first-child {
  flex-shrink: 0;
  color: #202124;
  font-weight: 700;
}

.cube-board {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 198rpx 198rpx;
  gap: 14rpx;
}

.cube-slot {
  position: relative;
  overflow: hidden;
  border: 1rpx dashed #DADCE0;
  border-radius: 16rpx;
  background: #F1F3F4;
}

.cube-slot.is-filled {
  border-style: solid;
  border-color: #E8EAED;
  background: #FFFFFF;
}

.cube-slot image {
  width: 100%;
  height: 100%;
  display: block;
}

.slot-top {
  grid-row: span 2;
}

.slot-empty {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(232, 240, 254, 0.88), rgba(241, 243, 244, 0.92));
  color: #9AA0A6;
  font-size: 58rpx;
  font-weight: 300;
}

.slot-label {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #202124;
  font-size: 20rpx;
  font-weight: 700;
}

.slot-hint {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  overflow: hidden;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(32, 33, 36, 0.72);
  color: #FFFFFF;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cube-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #5F6368;
  font-size: 22rpx;
  line-height: 1.45;
}

.cube-meta-action {
  flex-shrink: 0;
  color: #1A73E8;
  font-weight: 700;
}

.result-scroll {
  width: 100%;
  white-space: nowrap;
}

.result-row {
  display: flex;
  gap: 18rpx;
}

.result-card {
  width: 256rpx;
  flex-shrink: 0;
}

.result-skeleton {
  width: 256rpx;
  height: 392rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
}

.template-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.template-card {
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 22rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.08);
}

.template-card:nth-child(3n + 1) {
  background: #F8FBFF;
}

.template-card:nth-child(3n + 2) {
  background: #FBFAFF;
}

.template-top {
  display: grid;
  gap: 8rpx;
}

.template-title {
  color: #202124;
  font-size: 30rpx;
  font-weight: 700;
}

.template-tone {
  color: #1A73E8;
  font-size: 21rpx;
  font-weight: 700;
}

.template-desc {
  margin-top: 24rpx;
  color: #5F6368;
  font-size: 24rpx;
  line-height: 1.45;
}

.recommendation-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.08);
}

.recommendation-copy {
  min-width: 0;
}

.recommendation-images {
  display: flex;
  flex-shrink: 0;
}

.recommendation-images image {
  width: 78rpx;
  height: 98rpx;
  margin-left: -18rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 14rpx;
  background: #EEF2F7;
}

.recommendation-images image:first-child {
  margin-left: 0;
}

.recommendation-empty {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

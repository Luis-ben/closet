.result-page {
  padding-bottom: 0;
}

.poster-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid #E9E2D8;
  border-radius: 32rpx;
  background: #EFE5D3;
  box-shadow: 0 16rpx 42rpx rgba(31, 31, 31, 0.08);
}

.poster-image {
  width: 100%;
  height: 960rpx;
  display: block;
}

.poster-badge {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #1F1F1F;
  font-size: 24rpx;
  font-weight: 800;
}

.poster-skeleton {
  height: 960rpx;
  border-radius: 32rpx;
}

.info-card {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 36rpx rgba(31, 31, 31, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  color: #7A746E;
  font-size: 26rpx;
}

.info-row text:last-child {
  color: #1F1F1F;
  font-weight: 700;
}

.result-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 14rpx;
  padding: 22rpx 24rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(233, 226, 216, 0.86);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(31, 31, 31, 0.06);
}

.share-button {
  margin: 0;
  padding: 0;
  border: 0;
}

.share-button::after {
  border: 0;
}

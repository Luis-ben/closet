.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: minmax(0, auto) minmax(250rpx, 1fr);
  gap: 20rpx;
  align-items: center;
  padding: 22rpx 32rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(233, 226, 216, 0.86);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(31, 31, 31, 0.06);
}

.bottom-info {
  color: #7A746E;
  font-size: 24rpx;
  line-height: 1.35;
  white-space: nowrap;
}

.bottom-button {
  min-width: 0;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 48rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(17, 17, 17, 0.16);
}

.bottom-button.is-disabled {
  opacity: 0.42;
  box-shadow: none;
}

.loading-dot {
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.36);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

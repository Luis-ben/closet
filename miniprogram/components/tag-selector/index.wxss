.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  min-height: 56rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border: 1rpx solid #E9E2D8;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #1F1F1F;
  font-size: 26rpx;
}

.tag.is-selected {
  border-color: #111111;
  background: #111111;
  color: #FFFFFF;
  font-weight: 700;
}

.tag.is-disabled {
  opacity: 0.45;
}

.tag-note {
  font-size: 20rpx;
  opacity: 0.72;
}

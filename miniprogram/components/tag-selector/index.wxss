.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  min-height: 56rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border: 1rpx solid #DADCE0;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #3C4043;
  font-size: 26rpx;
}

.tag.is-selected {
  border-color: #D2E3FC;
  background: #E8F0FE;
  color: #174EA6;
  font-weight: 700;
}

.tag.is-disabled {
  opacity: 0.45;
}

.tag-note {
  font-size: 20rpx;
  opacity: 0.72;
}

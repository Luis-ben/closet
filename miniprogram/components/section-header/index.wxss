.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-main {
  min-width: 0;
}

.section-title {
  color: #202124;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.25;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #5F6368;
  font-size: 24rpx;
  line-height: 1.45;
}

.section-action {
  flex-shrink: 0;
  color: #1A73E8;
  font-size: 24rpx;
  font-weight: 700;
}

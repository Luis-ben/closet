<view class="empty">
  <view class="empty-art">
    <view class="empty-art__card card-a"></view>
    <view class="empty-art__card card-b"></view>
    <view class="empty-art__dot"></view>
  </view>
  <view class="empty-title">{{title}}</view>
  <view wx:if="{{description}}" class="empty-desc">{{description}}</view>
  <view wx:if="{{showButton && buttonText}}" class="empty-button" bindtap="onAction">
    {{buttonText}}
  </view>
</view>

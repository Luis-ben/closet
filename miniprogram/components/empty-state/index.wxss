.empty {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  border: 1rpx solid #E8EAED;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.08);
  text-align: center;
}

.empty-art {
  position: relative;
  width: 156rpx;
  height: 116rpx;
  margin-bottom: 26rpx;
}

.empty-art__card {
  position: absolute;
  border: 1rpx solid #E8EAED;
  border-radius: 14rpx;
  background: #E8F0FE;
}

.card-a {
  left: 12rpx;
  top: 8rpx;
  width: 92rpx;
  height: 104rpx;
}

.card-b {
  right: 8rpx;
  top: 0;
  width: 78rpx;
  height: 92rpx;
  background: #FFFFFF;
}

.empty-art__dot {
  position: absolute;
  right: 32rpx;
  bottom: 12rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #1A73E8;
}

.empty-title {
  color: #202124;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  max-width: 470rpx;
  margin-top: 10rpx;
  color: #5F6368;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-button {
  min-width: 210rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 0 28rpx;
  border-radius: 36rpx;
  background: #111111;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}

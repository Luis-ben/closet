.credit-pill {
  height: 58rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 22rpx;
  border: 1rpx solid #D2E3FC;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #174EA6;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.06);
}

.credit-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1A73E8;
}
